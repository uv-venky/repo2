# Postgres connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/repo2

# Session signing secret (required)
AUTH_SECRET=change-me-to-a-long-random-string

# Trust host header for local dev behind proxies
AUTH_TRUST_HOST=true

# Postgres search_path for venky-core tables (default: core,public)
VENKY_PG_SEARCH_PATH=core,public

# Dev: allow edited migration files after they were applied
NODE_ENV=development
VENKY_IGNORE_MIGRATION_CHECKSUM_MISMATCH=true

# Optional read-only replica
# READONLY_DATABASE_URL=
